{
  "name": "hyperliquid-ai-trader",
  "version": "2.0.0",
  "description": "Hyperliquid AI Trading System - Electron Desktop App",
  "main": "electron-main.js",
  "author": "AI Trader",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"python main_complete.py\" \"electron .\"",
    "dev": "concurrently \"python main_complete.py\" \"wait-on http://localhost:8000 && electron .\"",
    "build": "electron-builder",
    "dist": "npm run build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0",
    "framer-motion": "^10.16.4",
    "axios": "^1.6.0",
    "ws": "^8.14.0",
    "recharts": "^2.10.0",
    "i18next": "^23.7.0",
    "react-i18next": "^13.5.0",
    "react-icons": "^4.12.0",
    "date-fns": "^2.30.0",
    "nanoid": "^4.0.2"
  },
  "devDependencies": {
    "electron": "^latest",
    "electron-builder": "^24.6.4",
    "electron-vite": "^2.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.8",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16"
  },
  "build": {
    "appId": "com.tradingai.desktop",
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
