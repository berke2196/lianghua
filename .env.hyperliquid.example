# Hyperliquid API 环境配置示例
# 复制此文件为 .env 并填写您的配置

# API密钥
HYPERLIQUID_API_KEY=your-api-key-here
HYPERLIQUID_API_SECRET=your-api-secret-here

# 连接配置
HYPERLIQUID_TESTNET=false
HYPERLIQUID_TIMEOUT=30

# WebSocket配置
HYPERLIQUID_WS_RECONNECT=true
HYPERLIQUID_WS_RECONNECT_DELAY=5
HYPERLIQUID_WS_HEARTBEAT=30
HYPERLIQUID_WS_MAX_RETRIES=10
HYPERLIQUID_WS_MAX_QUEUE_SIZE=1000

# 交易配置
HYPERLIQUID_DEFAULT_ORDER_TYPE=limit
HYPERLIQUID_ENABLE_REDUCE_ONLY=false

# 日志配置
HYPERLIQUID_LOG_LEVEL=INFO
HYPERLIQUID_LOG_FILE=logs/hyperliquid.log

# API速率限制
HYPERLIQUID_RATE_LIMIT=100
