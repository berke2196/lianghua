# AsterDex HFT Trading System - Configuration Template
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────
# Backend API Configuration
# ─────────────────────────────────────────────
BACKEND_HOST=localhost
BACKEND_PORT=8000
BACKEND_RELOAD=False
BACKEND_ASTER_BASE=https://fapi.asterdex.com
BACKEND_ASTER_WS=wss://fstream.asterdex.com

# ─────────────────────────────────────────────
# CORS Configuration (allowed origins)
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log

# ─────────────────────────────────────────────
# Data Persistence
# ─────────────────────────────────────────────
HISTORY_FILE=trade_history.db
BACKUP_DIR=backups/

# ─────────────────────────────────────────────
# Trading Defaults
# ─────────────────────────────────────────────
DEFAULT_LEVERAGE=2
DEFAULT_TRADE_SIZE_USD=10
DEFAULT_STOP_LOSS_PCT=0.012
DEFAULT_TAKE_PROFIT_PCT=0.028
MAX_DAILY_LOSS_USD=50
MAX_OPEN_POSITIONS=3

# ─────────────────────────────────────────────
# API Timeouts (seconds)
# ─────────────────────────────────────────────
API_TIMEOUT=10
WEBSOCKET_TIMEOUT=30

# ─────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────
ENABLE_PAPER_TRADING=False
ENABLE_BACKTESTING=False

# ─────────────────────────────────────────────
# Frontend Configuration
# ─────────────────────────────────────────────
REACT_APP_API_BASE=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000/ws/frontend
REACT_APP_API_TIMEOUT=30000

# ─────────────────────────────────────────────
# Optional: Analytics & Monitoring
# ─────────────────────────────────────────────
# SENTRY_DSN=
# DATADOG_API_KEY=
