# ============================================================
#  AsterDex HFT - 环境变量模板
#  复制为 .env 并填写真实值（.env 已在 .gitignore 中，不会入库）
# ============================================================

# ── Telegram 告警（可选，填写后开启熔断/宕机推送）──
# 1. BotFather 创建 Bot，获取 Token
# 2. 向 Bot 发送任意消息，访问 https://api.telegram.org/bot<TOKEN>/getUpdates 获取 Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AsterDex API 端点（默认值已可用，无需修改）──
BACKEND_ASTER_BASE=https://fapi.asterdex.com
BACKEND_ASTER_WS=wss://fstream.asterdex.com

# ── 服务器部署关键配置 ──
# JWT密钥（首次运行自动生成写入.env，之后不要改动否则所有用户需重新登录）
JWT_SECRET=

# ⚠️ 私钥加密主密钥（必须修改！用于 Fernet 加密存储用户 API 私钥）
# 使用随机字符串，至少32位：python -c "import secrets; print(secrets.token_hex(32))"
# 警告：若保持默认值 changeme-please-set-secret-key，所有用户私钥加密强度极低！
SECRET_KEY=changeme-please-set-secret-key

# 管理员初始密码（首次启动建库时使用）
ADMIN_PASSWORD=ChangeMe123

# CORS允许的前端域名，多个用逗号分隔，服务器上改为你的真实域名/IP
# 例：CORS_ORIGINS=https://yourdomain.com,http://your-server-ip:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# 服务端口
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 前端访问后端的地址（服务器上改为真实IP/域名，build后生效）
REACT_APP_API_URL=http://localhost:8000

# ── 日志级别（INFO / DEBUG / WARNING）──
LOG_LEVEL=INFO

# ── 默认风控参数（可在前端设置页覆盖）──
DEFAULT_LEVERAGE=2
DEFAULT_TRADE_SIZE_USD=10
DEFAULT_STOP_LOSS_PCT=0.012
DEFAULT_TAKE_PROFIT_PCT=0.028
MAX_DAILY_LOSS_USD=50
MAX_OPEN_POSITIONS=3

# ── API 超时（秒）──
API_TIMEOUT=10

# ============================================================
#  ⚠️ 私钥安全说明
#  私钥不在此文件中配置！登录时通过前端界面输入，
#  仅存储在进程内存（SecureKeyStore），1小时自动过期。
#  绝对不要将私钥写入任何配置文件或环境变量。
# ============================================================
