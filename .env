# 环境变量配置示例
# 复制本文件为 .env 并无需填写API密钥
# 启动软件后直接扫码登录即可

# ========== Hyperliquid 扫码登录 =========
# 无需手动配置，启动应用后扫码即可
# 应用会自动处理认证和授权
HYPERLIQUID_MAINNET=true
HYPERLIQUID_SANDBOX_MODE=false

# ========== LLM API (用于AI分析) ==========
# 可选择 OpenAI 或其他
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# ========== 数据库 ==========
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_trader
REDIS_URL=redis://localhost:6379

# ========== 交易参数 ==========
TRADING_MODE=sandbox  # sandbox 或 live
INITIAL_CAPITAL=10000
MAX_LEVERAGE=2.0
DAILY_LOSS_LIMIT=0.1  # 10%

# ========== 监控和告警 ==========
TELEGRAM_BOT_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id
DISCORD_WEBHOOK=your_discord_webhook
ALERT_ENABLED=true

# ========== 日志 ==========
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/trader.log

# ========== 开发配置 ==========
DEBUG=false
ENVIRONMENT=production  # production 或 development
